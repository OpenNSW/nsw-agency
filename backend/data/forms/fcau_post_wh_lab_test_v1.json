{
  "schema": {
    "type": "object",
    "required": ["lab_result"],
    "properties": {
      "lab_result": {
        "type": "string",
        "title": "Microbiology & Pesticide Clearance (Post-Warehouse)",
        "oneOf": [
          { "const": "pass", "title": "Pass" },
          { "const": "fail", "title": "Fail" }
        ],
        "default": "pass"
      },
      "comments": {
        "type": "string",
        "title": "Laboratory Notes"
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/lab_result" },
      { "type": "Control", "scope": "#/properties/comments", "options": { "multi": true } }
    ]
  }
}
