{
  "schema": {
    "type": "object",
    "required": ["visual_outcome"],
    "properties": {
      "visual_outcome": {
        "type": "string",
        "title": "Visual Sample Assessment Outcome",
        "oneOf": [
          { "const": "pass", "title": "Pass - Satisfactory" },
          { "const": "fail", "title": "Fail - Unsatisfactory" },
          { "const": "lab_test_required", "title": "Lab Test Required" }
        ],
        "default": "pass"
      },
      "comments": {
        "type": "string",
        "title": "Assessment Comments"
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/visual_outcome" },
      { "type": "Control", "scope": "#/properties/comments", "options": { "multi": true } }
    ]
  }
}
