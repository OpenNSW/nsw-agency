{
  "schema": {
    "type": "object",
    "properties": {
      "reference_number": {
        "type": "string",
        "title": "Reference Number",
        "readOnly": true
      },
      "exporter_name": {
        "type": "string",
        "title": "Name of Applicant",
        "readOnly": true
      },
      "exporter_address": {
        "type": "string",
        "title": "Address of Applicant",
        "readOnly": true
      },
      "consignee_name": {
        "type": "string",
        "title": "Name of Consignee",
        "readOnly": true
      },
      "consignee_address": {
        "type": "string",
        "title": "Address of Consignee",
        "readOnly": true
      },
      "description_of_food": {
        "type": "string",
        "title": "Description of consignment and quantity",
        "readOnly": true
      },
      "intended_export_date": {
        "type": "string",
        "format": "date",
        "title": "Date of intended export",
        "readOnly": true
      },
      "lc_number": {
        "type": "string",
        "title": "L/C No",
        "readOnly": true
      },
      "container_numbers": {
        "type": "string",
        "title": "Container Numbers",
        "readOnly": true
      },
      "vessel_name": {
        "type": "string",
        "title": "Name of Vessel / Number",
        "readOnly": true
      },
      "consignment_storage_address": {
        "type": "string",
        "title": "Address where consignment is stored",
        "readOnly": true
      },
      "package_batch_weight_details": {
        "type": "string",
        "title": "Type of Package, Batch Codes and Total weight",
        "readOnly": true
      },
      "ingredients_details": {
        "type": "string",
        "title": "Details of ingredients used in product",
        "readOnly": true
      },
      "in_house_quality_monitoring": {
        "type": "string",
        "title": "Details of in-house quality monitoring",
        "readOnly": true
      },
      "analysis_certificates": {
        "type": "string",
        "format": "file",
        "title": "Raw Materials & Product Analysis Certificates",
        "readOnly": true
      },
      "other_declarations": {
        "type": "string",
        "title": "Any other Declarations",
        "readOnly": true
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/reference_number" },
      {
        "type": "Group",
        "label": "1. Consignment Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/exporter_name" },
              { "type": "Control", "scope": "#/properties/consignee_name" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/exporter_address" },
              { "type": "Control", "scope": "#/properties/consignee_address" }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "2. Transport & Export Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/intended_export_date" },
              { "type": "Control", "scope": "#/properties/lc_number" }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              { "type": "Control", "scope": "#/properties/container_numbers" },
              { "type": "Control", "scope": "#/properties/vessel_name" }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "3. Items & Specifications",
        "elements": [
          { "type": "Control", "scope": "#/properties/description_of_food" },
          { "type": "Control", "scope": "#/properties/consignment_storage_address" },
          { "type": "Control", "scope": "#/properties/package_batch_weight_details" }
        ]
      },
      {
        "type": "Group",
        "label": "4. Quality & Declarations",
        "elements": [
          { "type": "Control", "scope": "#/properties/ingredients_details", "options": { "multi": true } },
          { "type": "Control", "scope": "#/properties/in_house_quality_monitoring", "options": { "multi": true } },
          { "type": "Control", "scope": "#/properties/analysis_certificates" },
          { "type": "Control", "scope": "#/properties/other_declarations", "options": { "multi": true } }
        ]
      }
    ]
  }
}
