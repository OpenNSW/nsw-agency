# Port the NSW Agency server listens on
NSW_AGENCY_PORT=8081

# Database driver: sqlite | postgres
NSW_AGENCY_DB_DRIVER=sqlite

# SQLite settings (used if NSW_AGENCY_DB_DRIVER=sqlite)
NSW_AGENCY_DB_PATH=./nsw_agency_applications.db

# PostgreSQL settings (used if NSW_AGENCY_DB_DRIVER=postgres)
NSW_AGENCY_DB_HOST=localhost
NSW_AGENCY_DB_PORT=5432
NSW_AGENCY_DB_USER=postgres
NSW_AGENCY_DB_PASSWORD=changeme
NSW_AGENCY_DB_NAME=nsw_agency_db
NSW_AGENCY_DB_SSLMODE=disable

# Root directory containing task-configs/ and forms/ subdirectories
NSW_AGENCY_CONFIG_DIR=./data

# Fallback task config ID used when a request's taskCode has no registered config
NSW_AGENCY_DEFAULT_TASK_CONFIG_ID=default

# Comma-separated list of allowed CORS origins (use * to allow all)
NSW_AGENCY_ALLOWED_ORIGINS=*

# NSW outbound API settings used for NSW Agency -> NSW calls
NSW_AGENCY_NSW_API_BASE_URL=http://localhost:8080/api/v1

# OAuth2 client credentials (required)
# Local sample values align with idp/02-sample-resources.sh M2M app bootstrap
NSW_AGENCY_NSW_CLIENT_ID=NSW_AGENCY_TO_NSW
NSW_AGENCY_NSW_CLIENT_SECRET=1234
NSW_AGENCY_NSW_TOKEN_URL=https://localhost:8090/oauth2/token

# Optional comma-separated scopes
# NSW_AGENCY_NSW_SCOPES=

# DEV-ONLY: set to true to skip TLS verification for OAuth2 token endpoint
# Keep false in production.
NSW_AGENCY_NSW_TOKEN_INSECURE_SKIP_VERIFY=false